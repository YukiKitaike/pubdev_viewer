{
  "permissions": {
    "allow": [
      "Bash(git diff:*)",
      "Bash(git status:*)",
      "Bash(git log:*)",
      "Bash(fvm dart *)",
      "Bash(fvm flutter *)",
      "Bash(fvm list:*)",
      "WebFetch(domain:pub.dev)",
      "mcp__marionette__connect",
      "mcp__marionette__take_screenshots",
      "mcp__marionette__get_interactive_elements",
      "mcp__marionette__press_back_button",
      "mcp__marionette__tap",
      "mcp__marionette__scroll_to",
      "mcp__marionette__enter_text",
      "mcp__marionette__hot_reload",
      "mcp__marionette__get_logs",
      "Bash(marionette --uri *)",
      "Edit(/.claude/skills/**)",
      "Edit(/.claude/agents/**)",
      "Edit(/.claude/rules/**)"
    ],
    "deny": [
      "Bash(git push:*)",
      "Bash(git reset:*)",
      "Bash(git rebase:*)",
      "Bash(dart *)",
      "Bash(flutter *)",
      "Edit(**/*.g.dart)",
      "Edit(**/*.freezed.dart)"
    ]
  },
  "enableAllProjectMcpServers": true,
  "enabledMcpjsonServers": [
    "marionette"
  ],
  "hooks": {
    "PostToolUse": [
      {
        "matcher": "Edit|Write",
        "hooks": [
          {
            "type": "command",
            "timeout": 120,
            "command": "f=$(jq -r '.tool_input.file_path // empty'); case \"$f\" in *.freezed.dart|*.g.dart) exit 0;; *.dart) cd \"$CLAUDE_PROJECT_DIR\" && fvm dart format \"$f\" >/dev/null 2>&1; out=$(fvm dart analyze --fatal-infos 2>&1) || { printf '%s\\n' \"$out\" | tail -20 >&2; exit 2; };; esac"
          }
        ]
      }
    ]
  },
  "enabledPlugins": {
    "claude-md-management@claude-plugins-official": true,
    "claude-code-setup@claude-plugins-official": true,
    "skill-creator@claude-plugins-official": true,
    "plugin-dev@claude-plugins-official": true,
    "hookify@claude-plugins-official": true
  },
  "defaultMode": "plan"
}
