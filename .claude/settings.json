{
  "permissions": {
    "allow": [
      "Bash(find:*)",
      "Bash(rg:*)",
      "Bash(grep:*)",
      "Bash(ls:*)",
      "Bash(git diff:*)",
      "Bash(git add *)",
      "Bash(git commit *)",
      "Bash(fvm dart analyze *)",
      "Bash(fvm flutter test *)",
      "Bash(fvm dart run build_runner *)",
      "Bash(fvm dart pub *)",
      "Bash(fvm dart *)",
      "Bash(fvm flutter *)",
      "Bash(fvm list:*)",
      "WebFetch(domain:pub.dev)",
      "Bash(dart pub:*)",
      "Bash(echo \"Flutter app starting in background, PID: $!\")",
      "mcp__marionette__connect",
      "mcp__marionette__take_screenshots",
      "mcp__marionette__get_interactive_elements",
      "mcp__marionette__press_back_button",
      "mcp__marionette__tap",
      "mcp__marionette__scroll_to",
      "mcp__marionette__enter_text",
      "mcp__marionette__hot_reload",
      "mcp__marionette__get_logs",
      "Bash(marionette --uri *)",
      "Edit(/.claude/skills/pubdev-new-feature/**)",
      "Edit(/.claude/skills/pubdev-state/**)",
      "Edit(/.claude/skills/pubdev-models/**)",
      "Edit(/.claude/skills/pubdev-ui/**)"
    ],
    "deny": [
      "Bash(git push:*)",
      "Bash(git reset:*)",
      "Bash(git rebase:*)"
    ]
  },
  "enableAllProjectMcpServers": true,
  "enabledMcpjsonServers": [
    "marionette"
  ],
  "hooks": {
    "PreToolUse": [
      {
        "matcher": "Edit|Write",
        "hooks": [
          {
            "type": "command",
            "command": "if echo \"$CLAUDE_TOOL_INPUT\" | grep -qE '\\.(g|freezed)\\.dart'; then echo 'BLOCK: generated file — run build_runner instead'; exit 1; fi"
          }
        ]
      }
    ],
    "PostToolUse": [
      {
        "matcher": "Edit|Write|MultiEdit",
        "hooks": [
          {
            "type": "command",
            "command": "fvm dart format ."
          },
          {
            "type": "command",
            "command": "fvm dart analyze --fatal-infos 2>&1 | tail -5"
          }
        ]
      }
    ]
  },
  "enabledPlugins": {
    "claude-md-management@claude-plugins-official": true,
    "claude-code-setup@claude-plugins-official": true,
    "skill-creator@claude-plugins-official": true,
    "plugin-dev@claude-plugins-official": true,
    "hookify@claude-plugins-official": true
  },
  "defaultMode": "plan"
}
